{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "lib": [
      "dom",
      "ES2018"
    ],
    "module": "es2020",
    "moduleResolution": "bundler",
    "target": "es2018",
    "outDir": "build",
    "declaration": true,
    "esModuleInterop": true,
    "sourceMap": true,
    "rootDir": "src",
    "strictNullChecks": true,
    "importHelpers": true,
    "types": [
      "apple-signin-api",
      "facebook-js-sdk",
      "gapi",
      "gapi.auth2"
    ]
  },

  "exclude": [
    "node_modules"
  ],
  "include": [
    "src"
  ]
}
