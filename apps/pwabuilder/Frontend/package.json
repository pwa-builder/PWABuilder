{
  "name": "microsoft.pwabuilder",
  "version": "1.0.0",
  "description": "A developer tool for publishing Progressive Web Apps (PWAs) to app stores",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite build --mode preview && vite preview",
    "stop": "npm run kill-dev-server",
    "kill-dev-server": "kill-port 5173",
    "test": "playwright test",
    "preinstall": "node ../../../scripts/setupDeps.js"
